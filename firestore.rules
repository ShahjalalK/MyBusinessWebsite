rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isTrackFlowAdmin() {
      // IMPORTANT: Firestore rules cannot read .env values.
      // Add every admin Gmail here, matching ALLOWED_ADMIN_EMAILS in Vercel/ENV.
      return isSignedIn() && request.auth.token.email in [
        "rilph.o.neid@gmail.com"
      ];
    }

    match /outreach_leads/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    match /email_events/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    match /automation_settings/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    match /daily_sending_stats/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    match /suppression_list/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    match /contact_memory/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    match /system_status/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    match /system_locks/{docId} {
      allow read, create, update, delete: if isTrackFlowAdmin();
    }

    // Default deny for every unknown collection.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
